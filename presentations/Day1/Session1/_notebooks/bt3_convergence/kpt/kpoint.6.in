&CONTROL
    calculation  = "scf"
    outdir       = './tmp/',
    prefix       = 'MoS2',
    pseudo_dir   = './../../pseudo',
    restart_mode = "from_scratch"
/

&SYSTEM
  ibrav         = 0,
  nat           = 3,
  ntyp          = 2,
  ecutwfc       = 80,
  ecutrho       = 350,
  occupations   = 'smearing'
  smearing      = 'mv'
  degauss       = 0.005,
/

&ELECTRONS
  conv_thr      = 1.0d-8
/

