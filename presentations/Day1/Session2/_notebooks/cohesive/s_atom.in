&CONTROL
  calculation   = 'scf',
  prefix        = 's_atom',
  pseudo_dir    = './../pseudo',
  outdir        = './../tmp/',
/
&SYSTEM
  ibrav         = 1,
  a             = 15,
  nat           = 1,
  ntyp          = 1,
  ecutwfc       = 80,
  ecutrho       = 350,
  nspin         = 2
  tot_magnetization = 2.0,
  occupations    = 'smearing',
  smearing      = 'mv',
  degauss       = 0.005,
/
&ELECTRONS
  conv_thr      = 1.0d-8,
  mixing_beta   = 0.3,
/

ATOMIC_SPECIES
S      32.06500  S_ONCV_PBE_sr.upf

ATOMIC_POSITIONS (crystal)
S                7.500000        7.500000        7.500000

K_POINTS {gamma}
