&CONTROL
  calculation   = 'relax',
  prefix        = 'MoS2',
  pseudo_dir    = './../pseudo',
  outdir        = './tmp/',
  verbosity     = 'high',
/
&SYSTEM
  ibrav         = 4,
  a             = 9.55590,
  c             = 20.2700,
  nat           = 27,
  ntyp          = 2,
  ecutwfc       = 70,
  ecutrho       = 280,
  occupations   = 'smearing',
  smearing      = 'mv',
  degauss       = 0.005,
/

&ELECTRONS
  conv_thr      = 1.0d-6,
/

&IONS
ion_dynamics = 'bfgs',
/

