&control
    calculation = 'relax',
    prefix = 'H',
    outdir         = './../../tmp/',
    pseudo_dir     = './../../pseudo',
/

&SYSTEM
    ibrav       =  0
    nat         =  2
    ntyp        =  1
    degauss     =  0.01
    ecutrho     =  240
    ecutwfc     =  60
    occupations = 'smearing',
    smearing    = 'mv',
    degauss     = 0.005,
/

&ELECTRONS
    conv_thr         =  1.0e-06
    mixing_beta      =  0.4,
/

&IONS
ion_dynamics = 'bfgs',
/

K_POINTS {gamma}

CELL_PARAMETERS {angstrom}
 15.000000   0.000000   0.000000
  0.000000  15.000000   0.000000
  0.000000   0.000000  15.000000

ATOMIC_SPECIES
H       1.00794  H_ONCV_PBE_sr.upf

ATOMIC_POSITIONS (angstrom)
H                9.9247929201       10.0000000000       10.0000000000
H               10.6752070799       10.0000000000       10.0000000000
